<Window x:Class="ScadaWPF.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Tag History" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDark}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Info -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Name="txtTagInfo" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource AccentBlue}" Margin="0,0,20,0"/>
            <TextBlock Name="txtMin" Foreground="{StaticResource TextSecondary}" Margin="0,0,15,0"/>
            <TextBlock Name="txtMax" Foreground="{StaticResource TextSecondary}" Margin="0,0,15,0"/>
            <TextBlock Name="txtAvg" Foreground="{StaticResource TextSecondary}"/>
        </StackPanel>

        <!-- Grafik -->
        <oxy:PlotView Grid.Row="1" Name="plotView"
                      Background="{StaticResource BackgroundMedium}"/>

        <!-- Alarm linije info -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Rectangle Width="20" Height="3" Fill="Red" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <TextBlock Text="High Alarm" Foreground="{StaticResource TextSecondary}" Margin="0,0,15,0"/>
            <Rectangle Width="20" Height="3" Fill="Orange" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <TextBlock Text="Low Alarm" Foreground="{StaticResource TextSecondary}"/>
        </StackPanel>
    </Grid>
</Window>