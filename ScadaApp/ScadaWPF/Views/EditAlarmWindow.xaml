<Window x:Class="ScadaWPF.Views.EditAlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Alarm" Height="300" Width="350"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDark}">

    <StackPanel Margin="15">
        <Label Content="Limit:"/>
        <TextBox Name="txtLimit"/>

        <Label Content="Type:"/>
        <ComboBox Name="cmbType">
            <ComboBoxItem>High</ComboBoxItem>
            <ComboBoxItem>Low</ComboBoxItem>
        </ComboBox>

        <Label Content="Message:"/>
        <TextBox Name="txtMessage"/>

        <Button Content="Save" Width="100" Margin="0,15,0,0" Click="btnSave_Click"/>
    </StackPanel>
</Window>