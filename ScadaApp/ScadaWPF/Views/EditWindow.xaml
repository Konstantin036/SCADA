<Window x:Class="ScadaWPF.Views.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Tag" Height="600" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDark}">

    <StackPanel Margin="15">
        <Label Content="Tag Name:"/>
        <TextBox Name="txtTagName" IsEnabled="False"/>

        <Label Content="Description:"/>
        <TextBox Name="txtDescription"/>

        <Label Content="I/O Address:"/>
        <TextBox Name="txtIOAddress"/>

        <!-- Input only -->
        <StackPanel Name="pnlInput">
            <Label Content="Scan Time (ms):"/>
            <TextBox Name="txtScanTime"/>
        </StackPanel>

        <!-- Analog only -->
        <StackPanel Name="pnlAnalog">
            <Label Content="Low Limit:"/>
            <TextBox Name="txtLowLimit"/>
            <Label Content="High Limit:"/>
            <TextBox Name="txtHighLimit"/>
            <Label Content="Units:"/>
            <TextBox Name="txtUnits"/>
        </StackPanel>

        <!-- AI only -->
        <StackPanel Name="pnlAI">
            <Label Content="Deadband:"/>
            <TextBox Name="txtDeadband"/>
            <Label Content="Hysteresis:"/>
            <TextBox Name="txtHysteresis"/>
        </StackPanel>

        <!-- Output only -->
        <StackPanel Name="pnlOutput">
            <Label Content="Initial Value:"/>
            <TextBox Name="txtInitialValue"/>
        </StackPanel>

        <Button Content="Save" Width="100" Margin="0,15,0,0" Click="btnSave_Click"/>
    </StackPanel>
</Window>