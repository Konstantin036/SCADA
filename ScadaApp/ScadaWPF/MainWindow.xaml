<Window x:Class="ScadaWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SCADA Application" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BackgroundDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Name="btnAdd" Content="Add Tag/Alarm" Width="120" Margin="5"
                    Click="btnAdd_Click"
                    IsEnabled="{Binding IsAdmin}"
                    ToolTipService.ShowOnDisabled="True"
                    ToolTip="Samo Admin može dodavati tagove"/>
            <Button Name="btnReport" Content="Report" Width="80" Margin="5"
                    Click="btnReport_Click"
                    IsEnabled="{Binding IsAdmin}"
                    ToolTipService.ShowOnDisabled="True"
                    ToolTip="Samo Admin može generisati izveštaj"/>
            <Button Name="btnLogout" Content="Logout" Width="80" Margin="5"
                    Click="btnLogout_Click"/>
        </StackPanel>

        <!-- Tags lista -->
        <DataGrid Grid.Row="1" Name="dgTags" Margin="10"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tag Name" Binding="{Binding TagName}" Width="120"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="60"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="150"/>
                <DataGridTextColumn Header="I/O Address" Binding="{Binding IOAddress}" Width="100"/>
                <DataGridTextColumn Header="Current Value" Binding="{Binding CurrentValue, StringFormat=F2}" Width="100"/>
                <DataGridTemplateColumn Header="Scan" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsScanning, Mode=OneWay}"
                                      IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}}"
                                      ToolTipService.ShowOnDisabled="True"
                                      ToolTip="Samo Admin može menjati scan"
                                      Click="chkScan_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Details" Width="60" Margin="2"
                                        Click="btnDetails_Click"/>
                                <Button Content="History" Width="60" Margin="2"
                                        Click="btnHistory_Click"/>
                                <Button Content="Remove" Width="60" Margin="2"
                                        IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTipService.ShowOnDisabled="True"
                                        ToolTip="Samo Admin može brisati tagove"
                                        Click="btnRemove_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Alarm panel -->
        <GroupBox Grid.Row="2" Header="Active Alarms" Margin="10">
            <DataGrid Name="dgAlarms" AutoGenerateColumns="False" IsReadOnly="True" GotFocus="dgAlarms_GotFocus">
                    <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="Active">
                                <Setter Property="Background" Value="#7A1A1A"/>
                                <Setter Property="Foreground" Value="#FFAAAA"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="Acknowledged">
                                <Setter Property="Background" Value="#7A6A00"/>
                                <Setter Property="Foreground" Value="#FFD700"/>
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    <Condition Binding="{Binding State}" Value="Active"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#7A1A1A"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    <Condition Binding="{Binding State}" Value="Acknowledged"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#7A6A00"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tag" Binding="{Binding TagName}" Width="120"/>
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="200"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150"/>
                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
                    <DataGridTemplateColumn Header="Action" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Acknowledge"
                                        IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTipService.ShowOnDisabled="True"
                                        ToolTip="Samo Admin može acknowledge-ovati alarme"
                                        Click="btnAcknowledge_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>