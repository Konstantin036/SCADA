<Window x:Class="ScadaWPF.Views.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tag Details" Height="400" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Info -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Name="txtTagInfo" FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <!-- Alarmi -->
        <GroupBox Grid.Row="1" Header="Alarms">
            <DataGrid Name="dgAlarms" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Limit" Binding="{Binding Limit}" Width="80"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="60"/>
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="150"/>
                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
                    <DataGridTemplateColumn Header="Remove" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Click="btnRemoveAlarm_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>