<Window x:Class="ScadaWPF.Views.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tag Details" Height="400" Width="550"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDark}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Name="txtTagInfo" FontWeight="Bold" FontSize="14" Foreground="{StaticResource AccentBlue}"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Alarms">
            <DataGrid Name="dgAlarms" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Limit" Binding="{Binding Limit}" Width="80"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="60"/>
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="150"/>
                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
                    <DataGridTemplateColumn Header="Remove" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Edit" Width="55" Margin="2"
                                        IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTipService.ShowOnDisabled="True"
                                        ToolTip="Samo Admin može editovati alarme"
                                        Click="btnEditAlarm_Click"/>
                                    <Button Content="X" Width="35" Margin="2"
                                        IsEnabled="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTipService.ShowOnDisabled="True"
                                        ToolTip="Samo Admin može brisati alarme"
                                        Click="btnRemoveAlarm_Click"/>  
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>