<Window x:Class="ScadaWPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SCADA Login" Height="450" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundDark}">

    <StackPanel Margin="30">
        <TextBlock Text="SCADA Application" FontSize="18"
           FontWeight="Bold" HorizontalAlignment="Center"
           Foreground="{StaticResource AccentBlue}"
           Margin="0,0,0,20"/>

        <Label Content="Username:"/>
        <TextBox Name="txtUsername" Margin="0,0,0,10"/>

        <Label Content="Password:"/>
        <PasswordBox Name="txtPassword" Margin="0,0,0,20"/>

        <Button Name="btnLogin" Content="Login" Height="35"
                Click="btnLogin_Click"/>

        <TextBlock Name="txtError" Foreground="Red" 
                   HorizontalAlignment="Center" Margin="0,10,0,0"
                   TextWrapping="Wrap"/>

        <Separator Margin="0,20,0,10"/>

        <TextBlock Text="New user?" HorizontalAlignment="Center"
           Foreground="{StaticResource TextSecondary}"/>
        <Button Content="Register" Margin="0,8,0,0"
                Click="btnRegister_Click"/>
    </StackPanel>
</Window>